{
    "version": "1.0",
    "description": "Scene that loads an extensionNode via nodeTemplate and overrides its read-only Config property",
    "data": {
        "type": "scene",
        "name": "test",
        "rootNode": {
            "type": "node",
            "name": "root",
            "children": [
                {
                    "type": "external",
                    "name": "ext",
                    "source": {
                        "type": "nodeTemplate",
                        "url": "scene_extension_node_readonly_override.nodeTemplate"
                    },
                    "resourceGroup": "ro-override-grp",
                    "overrides": [
                        {
                            "path": ".Config",
                            "value": {
                                "properties": [
                                    { "name": "Setting", "value": 77 }
                                ]
                            }
                        }
                    ]
                }
            ]
        }
    }
}
