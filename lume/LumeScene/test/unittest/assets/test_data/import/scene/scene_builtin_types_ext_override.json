{
	"version": "1.0",
	"description": "external node with overrides setting each new builtin typed value",
	"data": {
		"type": "scene",
		"name": "test",
		"rootNode": {
			"type": "node",
			"children": [
				{
					"type": "external",
					"source": {
						"type": "nodeTemplate",
						"url": "scene_builtin_types_template.nodeTemplate"
					},
					"resourceGroup": "builtin-types-grp",
					"overrides": [
						{
							"path": ".!BuiltinAtt.UVec3",
							"value": { "type": "uvec3", "value": [7, 8, 9] }
						},
						{
							"path": ".!BuiltinAtt.UVec4",
							"value": { "type": "uvec4", "value": [1, 2, 3, 4] }
						},
						{
							"path": ".!BuiltinAtt.IVec2",
							"value": { "type": "ivec2", "value": [-5, 6] }
						},
						{
							"path": ".!BuiltinAtt.IVec3",
							"value": { "type": "ivec3", "value": [-5, 6, -7] }
						},
						{
							"path": ".!BuiltinAtt.IVec4",
							"value": { "type": "ivec4", "value": [-5, 6, -7, 8] }
						},
						{
							"path": ".!BuiltinAtt.Duration",
							"value": { "type": "timeSpan", "value": 2500 }
						}
					]
				}
			]
		}
	}
}
