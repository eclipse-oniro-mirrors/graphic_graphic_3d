{
    "version": "1.0",
    "description": "scene loads an external nodeTemplate containing a mesh and sets its submesh material via a resourceId-typed override value",
    "data": {
        "type": "scene",
        "name": "test",
        "index": "scene_ext_mesh_mat_override.index",
        "rootNode": {
            "type": "node",
            "children": [
                {
                    "type": "external",
                    "source": {
                        "type": "nodeTemplate",
                        "url": "node_template_mesh.json"
                    },
                    "resourceGroup": "ext-grp",
                    "overrides": [
                        {
                            "path": ".SubMeshes[0].Material",
                            "value": { "type": "resourceId", "name": "overrideMat" }
                        }
                    ]
                }
            ]
        }
    }
}
