{
    "version": "1.0",
    "description": "scene loads node_template_gltf_img_override; the template's index references a gltf-loaded image (no path)",
    "data": {
        "type": "scene",
        "name": "test",
        "rootNode": {
            "type": "node",
            "children": [
                {
                    "type": "external",
                    "name": "ext",
                    "source": {
