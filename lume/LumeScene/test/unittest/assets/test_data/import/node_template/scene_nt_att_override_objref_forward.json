{
    "version": "1.0",
    "description": "scene overrides a template attachment property with a forward objectRef",
    "data": {
        "type": "scene",
        "name": "test",
        "rootNode": {
            "type": "node",
            "children": [
                {
                    "type": "external",
                    "name": "ext",
                    "source": {
                        "type": "nodeTemplate",
                        "url": "node_template_upd_v1_att.json"
                    },
                    "resourceGroup": "ext-override-objref-group",
                    "overrides": [
                        {
                            "path": ".!TestAttachment.NodeRef",
                            "value": { "type": "objectRef", "path": "/target" }
                        }
                    ]
                },
                {
                    "type": "node",
                    "name": "target"
                }
            ]
        }
    }
}
