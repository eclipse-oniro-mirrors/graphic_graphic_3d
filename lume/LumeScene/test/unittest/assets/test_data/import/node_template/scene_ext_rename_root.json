{
    "version": "1.0",
    "description": "scene loads an external nodeTemplate and renames the template's root via the external entry's name field",
    "data": {
        "type": "scene",
        "name": "test",
        "rootNode": {
            "type": "node",
            "children": [
                {
                    "type": "external",
                    "name": "myRenamedRoot",
                    "source": {
                        "type": "nodeTemplate",
                        "url": "node_template_mesh.json"
                    },
                    "resourceGroup": "ext-grp"
                }
            ]
        }
    }
}
