{
    "version": "1.0",
    "description": "scene loads node_template_gltf_mat_override (gltf + template-index override of the gltf-defined material). Scene has no own index entry, so the template's index must apply the override to the gltf-loaded material.",
    "data": {
        "type": "scene",
        "name": "test",
        "rootNode": {
            "type": "node",
            "children": [
                {
                    "type": "external",
                    "name": "ext",
                    "source": {
                        "type": "nodeTemplate",
                        "url": "node_template_gltf_mat_override.json"
                    },
                    "resourceGroup": "mat-group"
                }
            ]
        }
    }
}
