{
    "version": "1.0",
    "description": "scene loading a node template through the resource manager via an external node resourceId reference",
    "data": {
        "type": "scene",
        "name": "test",
        "index": "index_node_template.json",
        "rootNode": {
            "type": "node",
            "children": [
                {
                    "type": "external",
                    "name": "ext-instance",
                    "source": {
                        "resourceId": { "name": "ext-node-template" }
                    },
                    "resourceGroup": "ext-group"
                }
            ]
        }
    }
}
