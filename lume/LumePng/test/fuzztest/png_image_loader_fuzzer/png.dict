# libFuzzer dictionary for the PNG byte format.
# Each entry teaches the mutator a byte string that's structurally meaningful
# so it can be inserted/overlaid as an atomic unit instead of being discovered
# by random bit-flipping. Dramatically shortens the time to reach the libpng
# decode path and the wrapper's size / channel / 3D-texture guards.
#
# Sources: PNG spec (RFC 2083 / ISO 15948), libpng documentation.

# 8-byte PNG signature (\r=\x0d \n=\x0a)
signature="\x89PNG\x0d\x0a\x1a\x0a"

# Critical chunks
ihdr="IHDR"
plte="PLTE"
idat="IDAT"
iend="IEND"

# Ancillary chunks
trns="tRNS"
sbit="sBIT"
srgb="sRGB"
gama="gAMA"
chrm="cHRM"
phys="pHYs"
time="tIME"
itxt="iTXt"
text="tEXt"
ztxt="zTXt"
bkgd="bKGD"
hist="hIST"
offs="oFFs"
pcal="pCAL"
iccp="iCCP"
splt="sPLT"

# Animated PNG (APNG)
actl="acTL"
fctl="fcTL"
fdat="fdAT"

# Common IHDR field values
bitdepth_1="\x01"
bitdepth_2="\x02"
bitdepth_4="\x04"
bitdepth_8="\x08"
bitdepth_16="\x10"
colortype_gray="\x00"
colortype_rgb="\x02"
colortype_palette="\x03"
colortype_gray_alpha="\x04"
colortype_rgba="\x06"
interlace_none="\x00"
interlace_adam7="\x01"

# Minimal valid PNG file prefix: signature + IHDR length + IHDR tag.
sig_plus_ihdr="\x89PNG\x0d\x0a\x1a\x0a\x00\x00\x00\x0dIHDR"

# Smallest valid IDAT chunk header (length 0 then "IDAT").
empty_idat="\x00\x00\x00\x00IDAT"

# IEND marker as a complete chunk (length 0, type IEND, CRC).
iend_chunk="\x00\x00\x00\x00IEND\xae\x42\x60\x82"
