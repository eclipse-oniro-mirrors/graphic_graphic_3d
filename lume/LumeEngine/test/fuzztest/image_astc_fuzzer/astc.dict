# ASTC libFuzzer dictionary: file magic and common block-dimension header bytes.

# 4-byte ASTC file magic
magic="\x13\xAB\xA1\x5C"

# magic + block dims (blockX, blockY, blockZ) for the common 2D footprints
blk_4x4="\x13\xAB\xA1\x5C\x04\x04\x01"
blk_5x5="\x13\xAB\xA1\x5C\x05\x05\x01"
blk_6x6="\x13\xAB\xA1\x5C\x06\x06\x01"
blk_8x8="\x13\xAB\xA1\x5C\x08\x08\x01"
blk_10x10="\x13\xAB\xA1\x5C\x0A\x0A\x01"
blk_12x12="\x13\xAB\xA1\x5C\x0C\x0C\x01"
